</div>

<script>
// ═══════════════════════════════════════
// 기본 프롬프트 (초기값)
// ═══════════════════════════════════════
const DEFAULT_PROMPTS = {
  role: `당신은 고등학교 교사로서 학교생활기록부 세부능력 및 특기사항(세특)을 작성하는 전문가입니다.
학생의 과제물과 수업 활동을 바탕으로, 교육과정 성취기준에 근거한 객관적이고 구체적인 세특을 작성합니다.

[학생 정보]
- 이름: {{학생이름}}
- 반/번호: {{반번호}}
- 과목: {{과목명}}

[2022 교육과정 성취기준]
{{성취기준}}

[교사 모범 예시 문장 - 문체·어휘·문장 구조 참고]
{{모범예시}}

[학생 과제물 내용]
{{과제내용}}`,

  rules: `[작성 규칙 - 반드시 준수]
1. 반드시 한국어로만 작성 (영문자, 알파벳 절대 금지)
2. 문장 끝은 반드시 ~함, ~임, ~보임, ~나타냄, ~드러냄 등 명사형 종결어미 사용
3. 학생 이름을 문장 안에 직접 넣지 않음
4. NEIS 바이트 기준 {{최대바이트}}바이트 이내로 작성 (한글 1자=2바이트, 영문/숫자/특수문자=1바이트)
5. 아래 금지어는 절대 사용하지 않음: {{금지어목록}}
6. 아래 주의어는 되도록 사용하지 않음: {{주의어목록}}
7. 학생의 실제 과제 내용·활동·탐구 주제를 구체적으로 반영
8. 성취기준의 핵심 역량과 연계하여 서술
9. 과장 없이 사실에 근거하여 긍정적으로 서술
10. 수행 내용, 탐구 주제, 발표 내용, 토론 활동 등 구체적 사실 포함
11. 단순 나열이 아닌 학생의 사고 과정과 성장이 드러나도록 서술
12. 모범 예시 문장의 어휘 수준·문장 길이·서술 방식을 최대한 따름`,

  output: `[출력 형식]
- 세특 문장만 출력
- 제목, 번호, 설명, 바이트 수, 작성자 정보 등 부가 내용 절대 출력하지 않음
- 여러 개의 문장이 자연스럽게 이어지는 하나의 단락으로 작성
- 줄바꿈 없이 연속된 문장으로 출력`
};

// ═══════════════════════════════════════
// 상태
// ═══════════════════════════════════════
const state = {
  apiKey: '',
  prompts: { ...DEFAULT_PROMPTS },
  forbidWords: ['대회','수상','영문','1등','최우수','입상','올림피아드','선수권','챔피언','금상','은상','동상'],
  cautionWords: ['우수한','탁월한','뛰어난','최고','완벽','훌륭한'],
  neisFiles: [],
  achFiles: [],
  assignFiles: [],
  students: [],
  currentTab: 'role',
  activeTextarea: null,
};

// ═══════════════════════════════════════
// 초기화
// ═══════════════════════════════════════
function init() {
  const saved = localStorage.getItem('setech-ai-v2');
  if (saved) {
    const s = JSON.parse(saved);
    if (s.apiKey) state.apiKey = s.apiKey;
    if (s.prompts) state.prompts = { ...DEFAULT_PROMPTS, ...s.prompts };
    if (s.forbidWords) state.forbidWords = s.forbidWords;
    if (s.cautionWords) state.cautionWords = s.cautionWords;
    if (s.exampleText) document.getElementById('exampleText').value = s.exampleText;
    if (s.achText) document.getElementById('achText').value = s.achText;
  }
  updateApiStatus();
  loadPromptsToEditor();
  renderWordTags();
  updateCounter('exampleText','exampleCounter');
}

function saveAll() {
  const data = {
    apiKey: state.apiKey,
    prompts: state.prompts,
    forbidWords: state.forbidWords,
    cautionWords: state.cautionWords,
    exampleText: document.getElementById('exampleText').value,
    achText: document.getElementById('achText').value,
  };
  localStorage.setItem('setech-ai-v2', JSON.stringify(data));
}

function saveSettings() {
  saveAll();
  const btn = event.target;
  const orig = btn.textContent;
  btn.textContent = '✅ 저장됨';
  setTimeout(() => btn.textContent = orig, 1500);
}

function updateCounter(taId, counterId) {
  const v = document.getElementById(taId).value;
  document.getElementById(counterId).textContent = v.length + '자';
}

// ═══════════════════════════════════════
// 모달
// ═══════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// API 키
function saveApiKey() {
  const k = document.getElementById('apiKeyInput').value.trim();
  if (!k) return;
  state.apiKey = k;
  updateApiStatus();
  saveAll();
  closeModal('apiModal');
}
function updateApiStatus() {
  document.getElementById('apiDot').classList.toggle('connected', !!state.apiKey);
  document.getElementById('apiStatus').textContent = state.apiKey ? 'Gemini 연결됨' : 'API 키 미설정';
  if (state.apiKey) document.getElementById('apiKeyInput').value = state.apiKey;
}

// ═══════════════════════════════════════
// 프롬프트 편집기
// ═══════════════════════════════════════
function openPromptModal() {
  loadPromptsToEditor();
  renderWordTags();
  openModal('promptModal');
}

function loadPromptsToEditor() {
  document.getElementById('prompt-role').value = state.prompts.role;
  document.getElementById('prompt-rules').value = state.prompts.rules;
  document.getElementById('prompt-output').value = state.prompts.output;
}

function switchTab(name) {
  state.currentTab = name;
  document.querySelectorAll('.prompt-tab').forEach((t,i) => {
    const tabs = ['role','rules','output','words'];
    t.classList.toggle('active', tabs[i] === name);
  });
  document.querySelectorAll('.prompt-section').forEach(s => s.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  // 현재 활성 textarea 추적
  const taMap = { role:'prompt-role', rules:'prompt-rules', output:'prompt-output' };
  if (taMap[name]) state.activeTextarea = document.getElementById(taMap[name]);
}

function insertVar(varName) {
  const ta = state.activeTextarea || document.getElementById('prompt-' + state.currentTab);
  if (!ta || ta.tagName !== 'TEXTAREA') return;
  const s = ta.selectionStart, e = ta.selectionEnd;
  ta.value = ta.value.slice(0, s) + varName + ta.value.slice(e);
  ta.selectionStart = ta.selectionEnd = s + varName.length;
  ta.focus();
}

// textarea 포커스 추적
['prompt-role','prompt-rules','prompt-output'].forEach(id => {
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('focus', () => state.activeTextarea = el);
  });
});

function savePrompts() {
  state.prompts.role = document.getElementById('prompt-role').value;
  state.prompts.rules = document.getElementById('prompt-rules').value;
  state.prompts.output = document.getElementById('prompt-output').value;
  saveAll();
  closeModal('promptModal');
  // 저장 확인
  const btn = document.querySelector('#promptModal .btn-primary');
  const orig = btn.textContent;
  btn.textContent = '✅ 저장됨';
  setTimeout(() => btn.textContent = orig, 1200);
}

function resetPrompts() {
  if (!confirm('프롬프트를 기본값으로 초기화할까요?')) return;
  state.prompts = { ...DEFAULT_PROMPTS };
  loadPromptsToEditor();
}

// ═══════════════════════════════════════
// 금지어 / 주의어
// ═══════════════════════════════════════
function renderWordTags() {
  renderTags('forbidTags', state.forbidWords, 'forbid');
  renderTags('cautionTags', state.cautionWords, 'caution');
}

function renderTags(containerId, words, type) {
  const el = document.getElementById(containerId);
  el.innerHTML = '';
  words.forEach((w, i) => {
    const span = document.createElement('span');
    span.className = `word-tag word-tag-${type === 'forbid' ? 'forbid' : 'caution'}`;
    span.innerHTML = `${w} <span class="word-tag-remove" onclick="removeWord('${type}',${i})">✕</span>`;
    el.appendChild(span);
  });
}

function addWord(e, type) {
  if (e.key !== 'Enter') return;
  addWordBtn(type);
}
function addWordBtn(type) {
  const input = document.getElementById(type === 'forbid' ? 'forbidInput' : 'cautionInput');
  const words = input.value.split(/[,，、\s]+/).map(w => w.trim()).filter(Boolean);
  words.forEach(w => {
    const arr = type === 'forbid' ? state.forbidWords : state.cautionWords;
    if (!arr.includes(w)) arr.push(w);
  });
  input.value = '';
  renderWordTags();
}
function removeWord(type, idx) {
  if (type === 'forbid') state.forbidWords.splice(idx, 1);
  else state.cautionWords.splice(idx, 1);
  renderWordTags();
}

// ═══════════════════════════════════════
// 스텝 네비게이션
// ═══════════════════════════════════════
function goStep(n) {
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.style.display = i === n ? 'block' : 'none';
    const ind = document.getElementById('step' + i + '-ind');
    if (ind) {
      ind.classList.remove('active','done');
      if (i === n) ind.classList.add('active');
      else if (i < n) ind.classList.add('done');
    }
  }
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ═══════════════════════════════════════
// 파일 업로드
// ═══════════════════════════════════════
function onDrag(e, zoneId) { e.preventDefault(); document.getElementById(zoneId).classList.add('dragover'); }
function offDrag(zoneId) { document.getElementById(zoneId).classList.remove('dragover'); }
function onDrop(e, type) { e.preventDefault(); offDrag({neis:'neisZone',ach:'achZone',assign:'assignZone'}[type]); handleFiles(e.dataTransfer.files, type); }
function handleFile(e, type) { handleFiles(e.target.files, type); }

function handleFiles(files, type) {
  const arr = Array.from(files);
  if (type === 'neis') {
    arr.forEach(f => { if (!state.neisFiles.find(x=>x.name===f.name)) state.neisFiles.push({file:f,name:f.name}); });
    renderFileList('neis-files', state.neisFiles, 'neis');
    parseNeisFiles();
  } else if (type === 'ach') {
    arr.forEach(f => { if (!state.achFiles.find(x=>x.name===f.name)) state.achFiles.push({file:f,name:f.name}); });
    renderFileList('ach-files', state.achFiles, 'ach');
  } else if (type === 'assign') {
    arr.forEach(f => { if (!state.assignFiles.find(x=>x.name===f.name)) state.assignFiles.push({file:f,name:f.name,type:getFileType(f.name)}); });
    renderFileList('assign-files', state.assignFiles, 'assign');
  }
}

function getFileType(name) {
  const ext = name.split('.').pop().toLowerCase();
  if (ext==='pdf') return 'pdf';
  if (['xlsx','xls'].includes(ext)) return 'excel';
  if (['docx','doc'].includes(ext)) return 'word';
  return 'unknown';
}
function fileIcon(type) { return {pdf:'📄',excel:'📊',word:'📝',neis:'📋',ach:'🎯',unknown:'📎'}[type]||'📎'; }
function formatSize(b) { return b<1024?b+'B':b<1024*1024?(b/1024).toFixed(1)+'KB':(b/1024/1024).toFixed(1)+'MB'; }

function renderFileList(cId, files, type) {
  const el = document.getElementById(cId);
  el.innerHTML = '';
  files.forEach((f,i) => {
    const d = document.createElement('div');
    d.className = 'file-item';
    d.innerHTML = `<span class="file-icon">${fileIcon(f.type||type)}</span>
      <span class="file-name">${f.name}</span>
      <span class="file-size">${f.file?formatSize(f.file.size):''}</span>
      ${f.status?`<span class="file-status ok">${f.status}</span>`:''}
      <span class="file-remove" onclick="removeFile('${type}',${i})">✕</span>`;
    el.appendChild(d);
  });
}

function removeFile(type, idx) {
  if (type==='neis') state.neisFiles.splice(idx,1), renderFileList('neis-files',state.neisFiles,'neis');
  else if (type==='ach') state.achFiles.splice(idx,1), renderFileList('ach-files',state.achFiles,'ach');
  else if (type==='assign') state.assignFiles.splice(idx,1), renderFileList('assign-files',state.assignFiles,'assign');
}

// ═══════════════════════════════════════
// NEIS 파일 파싱
// ═══════════════════════════════════════
function parseNeisFiles() {
  state.students = [];
  let remaining = state.neisFiles.length;
  if (!remaining) return;
  state.neisFiles.forEach((nf, fi) => {
    const reader = new FileReader();
    reader.onload = e => {
      const wb = XLSX.read(e.target.result, {type:'binary'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, {header:1});
      for (let i = 1; i < rows.length; i++) {
        const r = rows[i];
        if (!r||!r[7]) continue;
        state.students.push({fileIdx:fi,fileName:nf.name,year:r[0],semester:r[1],grade:r[2],studentId:r[3],subject:r[4],subjectCode:r[5],classNum:r[6],name:r[7],status:r[8],setech:r[9]||'',rowIdx:i,assignFile:null,result:'',bytes:0});
      }
      nf.status = `${state.students.filter(s=>s.fileIdx===fi).length}명`;
      remaining--;
      if (remaining===0) renderFileList('neis-files',state.neisFiles,'neis');
    };
    reader.readAsBinaryString(nf.file);
  });
}

// ═══════════════════════════════════════
// 매칭
// ═══════════════════════════════════════
function runMatch() {
  if (!state.students.length) { alert('먼저 NEIS 양식 파일을 업로드해주세요.'); return; }
  if (!state.assignFiles.length) { goStep(3); return; }
  state.students.forEach(s => {
    s.assignFile = null;
    const [cls, num] = (s.classNum||'').split('/');
    for (const af of state.assignFiles) {
      const fn = af.name;
      if (fn.includes(s.name)) { s.assignFile = af; break; }
      const patterns = [`${cls}반${num}번`,`${cls}반${parseInt(num)}번`,`${cls}-${String(num).padStart(2,'0')}`,`${cls}-${parseInt(num)}`,`${cls}_${String(num).padStart(2,'0')}`,`${cls}${String(num).padStart(2,'0')}`];
      if (patterns.some(p=>fn.includes(p))) { s.assignFile = af; break; }
    }
  });
  const matched = state.students.filter(s=>s.assignFile).length;
  const unmatched = state.students.length - matched;
  document.getElementById('matchPanel').style.display = 'block';
  document.getElementById('matchResult').innerHTML = `
    <div style="display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;">
      <div style="background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.2);border-radius:8px;padding:10px 16px;font-size:13px;">✅ 자동 매칭 <strong style="color:var(--green)">${matched}명</strong></div>
      <div style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);border-radius:8px;padding:10px 16px;font-size:13px;">⚠️ 미매칭 <strong style="color:var(--yellow)">${unmatched}명</strong>${unmatched?' (AI가 내용으로 재매칭 시도)':''}</div>
    </div>`;
  goStep(3);
}

// ═══════════════════════════════════════
// 파일 내용 읽기
// ═══════════════════════════════════════
async function readFileContent(fileObj) {
  return new Promise(resolve => {
    const file = fileObj.file, type = fileObj.type;
    if (type==='excel') {
      const r = new FileReader();
      r.onload = e => { const wb=XLSX.read(e.target.result,{type:'binary'}); let t=''; wb.SheetNames.forEach(sn=>t+=XLSX.utils.sheet_to_csv(wb.Sheets[sn])+'\n'); resolve(t); };
      r.readAsBinaryString(file);
    } else if (type==='word') {
      const r = new FileReader();
      r.onload = e => mammoth.extractRawText({arrayBuffer:e.target.result}).then(res=>resolve(res.value)).catch(()=>resolve(''));
      r.readAsArrayBuffer(file);
    } else if (type==='pdf') {
      const r = new FileReader();
      r.onload = e => resolve({isPDF:true,base64:e.target.result.split(',')[1],mimeType:'application/pdf'});
      r.readAsDataURL(file);
    } else {
      const r = new FileReader();
      r.onload = e => resolve(e.target.result);
      r.readAsText(file,'utf-8');
    }
  });
}

// ═══════════════════════════════════════
// 바이트 계산
// ═══════════════════════════════════════
function calcBytes(str) {
  let b = 0;
  for (const c of str) b += c.charCodeAt(0) > 127 ? 2 : 1;
  return b;
}

// ═══════════════════════════════════════
// 프롬프트 빌드
// ═══════════════════════════════════════
function buildPrompt(student, content, isText) {
  const maxBytes = document.getElementById('maxBytes').value;
  const examples = document.getElementById('exampleText').value.trim();
  const achText = document.getElementById('achText').value.trim();
  const forbid = state.forbidWords.join(', ');
  const caution = state.cautionWords.join(', ');

  const replace = (tpl) => tpl
    .replace(/{{학생이름}}/g, student.name)
    .replace(/{{반번호}}/g, student.classNum)
    .replace(/{{과목명}}/g, student.subject)
    .replace(/{{최대바이트}}/g, maxBytes)
    .replace(/{{성취기준}}/g, achText || '(성취기준 미입력 - 과목 특성에 맞게 작성)')
    .replace(/{{모범예시}}/g, examples || '(예시 미입력)')
    .replace(/{{과제내용}}/g, isText ? (content||'(내용 없음)') : '[첨부 PDF 파일 참조]')
    .replace(/{{금지어목록}}/g, forbid || '없음')
    .replace(/{{주의어목록}}/g, caution || '없음');

  return [
    replace(state.prompts.role),
    replace(state.prompts.rules),
    replace(state.prompts.output)
  ].join('\n\n');
}

// ═══════════════════════════════════════
// Gemini 호출
// ═══════════════════════════════════════
async function callGemini(prompt, pdfData=null) {
  if (!state.apiKey) throw new Error('API 키가 설정되지 않았습니다.');
  const model = document.getElementById('geminiModel').value;
  const parts = [];
  if (pdfData) parts.push({inline_data:{mime_type:pdfData.mimeType,data:pdfData.base64}});
  parts.push({text:prompt});
  const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${state.apiKey}`,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({contents:[{parts}],generationConfig:{temperature:0.7,maxOutputTokens:1024}})
  });
  if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||'API 오류'); }
  const data = await res.json();
  return data.candidates?.[0]?.content?.parts?.[0]?.text || '';
}

// ═══════════════════════════════════════
// 생성
// ═══════════════════════════════════════
async function startGeneration() {
  if (!state.apiKey) { openModal('apiModal'); return; }
  if (!state.students.length) { alert('NEIS 양식 파일을 먼저 업로드해주세요.'); goStep(1); return; }

  const genBtn = document.getElementById('genBtn');
  genBtn.disabled = true;
  genBtn.textContent = '⏳ 생성 중...';
  document.getElementById('progressWrap').style.display = 'block';
  document.getElementById('progressBar').style.width = '0%';
  document.getElementById('genStatus').className = 'alert alert-info';
  document.getElementById('genStatus').textContent = '세특 생성을 시작합니다...';
  document.getElementById('genLog').innerHTML = '';

  const total = state.students.length;
  let done = 0;

  for (const student of state.students) {
    addLog(`⏳ ${student.classNum} ${student.name} 처리 중...`);
    try {
      let prompt='', pdfData=null;
      if (student.assignFile) {
        const content = await readFileContent(student.assignFile);
        if (content?.isPDF) { pdfData=content; prompt=buildPrompt(student,'',false); }
        else prompt = buildPrompt(student,content||'',true);
      } else {
        prompt = buildPrompt(student,'(과제물 미제출 또는 매칭 실패 — 수업 참여 태도 및 일반적 성취 내용으로 작성)', true);
      }
      const result = await callGemini(prompt, pdfData);
      student.result = result.trim();
      student.bytes = calcBytes(student.result);
      addLog(`✅ ${student.classNum} ${student.name} 완료 (${student.bytes}바이트)`);
    } catch(err) {
      student.result = '';
      student.bytes = 0;
      addLog(`❌ ${student.classNum} ${student.name} 오류: ${err.message}`);
    }
    done++;
    document.getElementById('progressBar').style.width = (done/total*100)+'%';
    document.getElementById('genStatus').textContent = `${done} / ${total} 완료`;
    await new Promise(r=>setTimeout(r,500));
  }

  document.getElementById('genStatus').textContent = `✅ 전체 ${total}명 생성 완료! 결과를 확인하고 수정하세요.`;
  genBtn.textContent = '🚀 세특 생성 시작';
  genBtn.disabled = false;
  renderResults();
  goStep(4);
}

function addLog(msg) {
  const log = document.getElementById('genLog');
  log.innerHTML += `<div>${msg}</div>`;
  log.scrollTop = log.scrollHeight;
}

// ═══════════════════════════════════════
// 결과 렌더링
// ═══════════════════════════════════════
function renderResults() {
  const tbody = document.getElementById('resultBody');
  const maxB = parseInt(document.getElementById('maxBytes').value);
  tbody.innerHTML = '';
  const ok = state.students.filter(s=>s.result&&s.bytes<=maxB).length;
  const over = state.students.filter(s=>s.bytes>maxB).length;
  const empty = state.students.filter(s=>!s.result).length;
  document.getElementById('resultSummary').textContent = `전체 ${state.students.length}명 · ✅ ${ok}명 완료 · ⚠️ ${over}명 초과 · ❌ ${empty}명 미완`;

  state.students.forEach((s,i) => {
    const bytes = s.bytes||0;
    let bc = bytes>maxB?'byte-over':bytes>maxB*0.95?'byte-warn':'byte-ok';
    let st = !s.result?'<span class="status-dot dot-error"></span>미생성':bytes>maxB?'<span class="status-dot dot-error"></span>초과':'<span class="status-dot dot-done"></span>완료';
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="white-space:nowrap;color:var(--text2);">${s.classNum}</td>
      <td style="white-space:nowrap;font-weight:500;">${s.name}</td>
      <td class="td-setech">
        <textarea class="setech-edit" id="setech-${i}" oninput="updateBytes(${i})">${s.result||''}</textarea>
        <div class="byte-count ${bc}" id="bytes-${i}">${bytes} / ${maxB} 바이트</div>
      </td>
      <td style="white-space:nowrap;" class="${bc}" id="byte-num-${i}">${bytes}</td>
      <td style="white-space:nowrap;" id="status-${i}">${st}</td>`;
    tbody.appendChild(tr);
  });
}

function updateBytes(i) {
  const ta = document.getElementById('setech-'+i);
  const bytes = calcBytes(ta.value);
  const maxB = parseInt(document.getElementById('maxBytes').value);
  state.students[i].result = ta.value;
  state.students[i].bytes = bytes;
  let cls = bytes>maxB?'byte-over':bytes>maxB*0.95?'byte-warn':'byte-ok';
  document.getElementById('bytes-'+i).textContent = `${bytes} / ${maxB} 바이트`;
  document.getElementById('bytes-'+i).className = `byte-count ${cls}`;
  document.getElementById('byte-num-'+i).textContent = bytes;
  document.getElementById('byte-num-'+i).className = cls;
}

// ═══════════════════════════════════════
// Excel 다운로드
// ═══════════════════════════════════════
async function downloadExcel() {
  if (!state.students.length) return;
  const groups = {};
  state.students.forEach(s => { if (!groups[s.fileName]) groups[s.fileName]=[]; groups[s.fileName].push(s); });
  for (const [fileName, students] of Object.entries(groups)) {
    const nf = state.neisFiles.find(f=>f.name===fileName);
    if (!nf) continue;
    await new Promise(resolve => {
      const reader = new FileReader();
      reader.onload = e => {
        const wb = XLSX.read(e.target.result,{type:'binary'});
        const ws = wb.Sheets[wb.SheetNames[0]];
        const rows = XLSX.utils.sheet_to_json(ws,{header:1});
        students.forEach(s => {
          if (rows[s.rowIdx]) {
            while(rows[s.rowIdx].length<10) rows[s.rowIdx].push('');
            rows[s.rowIdx][9] = s.result||'';
          }
        });
        wb.Sheets[wb.SheetNames[0]] = XLSX.utils.aoa_to_sheet(rows);
        XLSX.writeFile(wb, fileName.replace(/\.xlsx?$/,'_세특입력완료.xlsx'));
        resolve();
      };
      reader.readAsBinaryString(nf.file);
    });
  }
}

