      <button class="btn btn-ghost" onclick="goStep(1)">← 이전</button>
      <button class="btn btn-primary" onclick="runMatch()">매칭 확인 후 다음 →</button>
    </div>
  </div>

  <!-- STEP 3 -->
  <div id="step3" style="display:none;">
