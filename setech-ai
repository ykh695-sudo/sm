        <div>
          <label class="field-label">Gemini 모델</label>
          <select id="geminiModel">
            <option value="gemini-1.5-flash">Gemini 1.5 Flash (빠름·무료)</option>
            <option value="gemini-1.5-pro">Gemini 1.5 Pro (고품질)</option>
            <option value="gemini-2.0-flash">Gemini 2.0 Flash (최신)</option>
          </select>
        </div>
      </div>
    </div>
    <div class="panel">
      <div class="panel-title">🤖 세특 생성</div>
      <div id="genStatus" class="alert alert-info">생성 버튼을 누르면 AI가 학생별 세특을 작성합니다.</div>
      <div class="progress-wrap" id="progressWrap" style="display:none;">
        <div class="progress-bar" id="progressBar" style="width:0%"></div>
      </div>
      <div id="genLog" style="font-size:11px;color:var(--text3);max-height:150px;overflow-y:auto;margin-top:8px;"></div>
    </div>
    <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
      <button class="btn btn-ghost" onclick="goStep(2)">← 이전</button>
      <button class="btn btn-primary" id="genBtn" onclick="startGeneration()">🚀 세특 생성 시작</button>
    </div>
  </div>

  <!-- STEP 4 -->
  <div id="step4" style="display:none;">
    <div class="action-bar">
      <div class="action-bar-left"><span style="font-size:13px;color:var(--text2);" id="resultSummary"></span></div>
      <div class="action-bar-right">
        <button class="btn btn-ghost" onclick="goStep(3)">← 다시 생성</button>
        <button class="btn btn-green" onclick="downloadExcel()">⬇️ NEIS Excel 다운로드</button>
      </div>
    </div>
    <div class="result-table-wrap">
      <table>
        <thead>
          <tr>
            <th>반/번호</th><th>성명</th>
            <th class="td-setech">세부능력 및 특기사항 <span style="font-weight:300;font-size:11px;">(직접 수정 가능)</span></th>
            <th>바이트</th><th>상태</th>
          </tr>
        </thead>
        <tbody id="resultBody"></tbody>
      </table>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-top:16px;">
      <button class="btn btn-green" onclick="downloadExcel()">⬇️ NEIS Excel 다운로드</button>
    </div>
